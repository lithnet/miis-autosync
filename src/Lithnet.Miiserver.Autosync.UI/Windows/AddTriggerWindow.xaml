<wpfui:FluentWindow x:Class="Lithnet.Miiserver.AutoSync.UI.Windows.AddTriggerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:Lithnet.Miiserver.AutoSync.UI"
        xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
        WindowStartupLocation="CenterOwner"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        ShowInTaskbar="False"
        SizeToContent="Height"
        FontFamily="Segoe UI"
        Title="Add Trigger" Width="420">
    <wpfui:FluentWindow.Resources>
        <ui:TypeDescriptionConverter x:Key="typeConverter"/>
    </wpfui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <wpfui:TitleBar Grid.Row="0" Title="Add Trigger" ShowMinimize="False" ShowMaximize="False"/>

        <Grid Grid.Row="1" Margin="12 4 12 12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Margin="8" Text="Select trigger type"></TextBlock>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Trigger type" Margin="8 5 8 5" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AllowedTriggers}"
                          SelectedItem="{Binding SelectedTrigger}"
                          Margin="0 5 8 5"
                          VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource typeConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
            <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Margin="0 16 0 0">
                <Button Content="OK" Margin="0 0 8 0" MinWidth="80" IsDefault="True" Click="Button_Click_OK" />
                <Button Content="Cancel" MinWidth="80" Click="Button_Click_Cancel"/>
            </StackPanel>
        </Grid>
    </Grid>
</wpfui:FluentWindow>

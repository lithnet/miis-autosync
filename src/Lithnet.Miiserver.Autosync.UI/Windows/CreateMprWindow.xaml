<wpfui:FluentWindow x:Class="Lithnet.Miiserver.AutoSync.UI.Windows.CreateMprWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:Lithnet.Miiserver.AutoSync.UI"
        xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml" WindowStartupLocation="CenterOwner"
        mc:Ignorable="d" ResizeMode="NoResize" ExtendsContentIntoTitleBar="True" ShowInTaskbar="False"
        SizeToContent="Height"
        FontFamily="Segoe UI"
        Title="Create MIM service permissions" Width="460">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <wpfui:TitleBar Grid.Row="0" Title="Create MIM service permissions" ShowMinimize="False" ShowMaximize="False"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Top">
        <TextBlock Margin="8 8 8 20"
                   TextWrapping="Wrap"
                   >This will create a new set containing the AutoSync service account, and grant access to read the msidmCompletedTime attribute of all Request objects</TextBlock>
        <Grid >
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Grid.Row="0"
                       Text="MIM service hostname"
                       HorizontalAlignment="Right"
                       Margin="5"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="1"
                     Grid.Row="0"
                     Margin="5"
                     Text="{Binding Path=MimServiceHost}"/>

            <TextBlock Grid.Column="0" 
                       Grid.Row="1"
                       Text="MPR Name"
                       HorizontalAlignment="Right" 
                       Margin="5" 
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="1"
                     Grid.Row="1"
                     Margin="5"
                     Text="{Binding Path=MprName}"/>

            <TextBlock Grid.Column="0" 
                       Grid.Row="2"
                       Text="Set Name"
                       HorizontalAlignment="Right" 
                       Margin="5" 
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="1"
                     Grid.Row="2"
                     Margin="5"
                     Text="{Binding Path=SetName}"/>

            <TextBlock Grid.Column="0" 
                       Grid.ColumnSpan="2"
                       Grid.Row="3"
                       Text="Credentials (leave blank to use the credentials of the currently logged on user)"
                       HorizontalAlignment="Left" 
                       Margin="5" 
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="0" 
                       Grid.Row="4"
                       Text="Username"
                       HorizontalAlignment="Right" 
                       Margin="5" 
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="1"
                     Grid.Row="4"
                     Margin="5"
                     Text="{Binding Path=Username}"/>

            <TextBlock Grid.Column="0" 
                       Grid.Row="5"
                       Text="Password"
                       HorizontalAlignment="Right" 
                       Margin="5" 
                       VerticalAlignment="Center"/>
            <PasswordBox Grid.Row="5" 
                         Grid.Column="1" 
                         Margin="5" 
                         PasswordChar="*" 
                         ui:PasswordBoxBindingHelper.Password="{Binding Path=Password}" 
            />

        </Grid>
        
        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Margin="12">
            <Button Content="OK" Margin="0 0 8 0" MinWidth="80" IsDefault="True" Click="Button_Click_OK" />
            <Button Content="Cancel" MinWidth="80" Click="Button_Click_Cancel"/>
        </StackPanel>

    </StackPanel>
    </Grid>
</wpfui:FluentWindow>

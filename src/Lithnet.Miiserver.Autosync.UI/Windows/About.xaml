<wpfui:FluentWindow x:Class="Lithnet.Miiserver.AutoSync.UI.Windows.About"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
                    WindowStartupLocation="CenterOwner"
                    mc:Ignorable="d"
                    ResizeMode="NoResize"
                    ExtendsContentIntoTitleBar="True"
                    SizeToContent="WidthAndHeight"
                    ShowInTaskbar="False"
                    FontFamily="Segoe UI"
                    Title="About" MinWidth="360">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <wpfui:TitleBar Grid.Row="0" Title="About" ShowMinimize="False" ShowMaximize="False" />

        <StackPanel Grid.Row="1" Margin="32 12 32 24" HorizontalAlignment="Center">
            <Image Source="/Resources/autosync-256.png" Width="96" Height="96" HorizontalAlignment="Center" />
            <wpfui:TextBlock Text="Lithnet AutoSync" FontTypography="Subtitle" HorizontalAlignment="Center" Margin="0 12 0 0" />
            <TextBlock Name="TxVersion" Text="Version" HorizontalAlignment="Center" Margin="0 4 0 0" />
            <Button Content="OK" MinWidth="80" IsDefault="True" HorizontalAlignment="Center" Margin="0 20 0 0" Click="Button_Click" />
        </StackPanel>
    </Grid>
</wpfui:FluentWindow>

<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Class="Lithnet.Miiserver.AutoSync.UI.TimeSpanControl"
    Height="Auto"
    Width="Auto"
    x:Name="TsControl">

    <StackPanel Orientation="Horizontal">
        <wpfui:NumberBox x:Name="UdDays" Value="{Binding Path=Days, ElementName=TsControl, UpdateSourceTrigger=PropertyChanged}" Minimum="0" MaxDecimalPlaces="0" Margin="0 0 5 0"/>
        <TextBlock Text="days" VerticalAlignment="Center"/>
        <wpfui:NumberBox x:Name="UdHours" Value="{Binding Path=Hours, ElementName=TsControl, UpdateSourceTrigger=PropertyChanged}" Minimum="0" Maximum="23" MaxDecimalPlaces="0" Margin="5 0 5 0"/>
        <TextBlock Text="hours" VerticalAlignment="Center"/>
        <wpfui:NumberBox x:Name="UdMinutes" Value="{Binding Path=Minutes, ElementName=TsControl, UpdateSourceTrigger=PropertyChanged}" Minimum="0" Maximum="59" MaxDecimalPlaces="0" Margin="5 0 5 0"/>
        <TextBlock Text="minutes" VerticalAlignment="Center"/>
        <wpfui:NumberBox x:Name="UdSeconds" Value="{Binding Path=Seconds, ElementName=TsControl, UpdateSourceTrigger=PropertyChanged}" Minimum="0" Maximum="59" MaxDecimalPlaces="0" Margin="5 0 5 0" />
        <TextBlock Text="seconds" VerticalAlignment="Center"/>
    </StackPanel>
</UserControl>

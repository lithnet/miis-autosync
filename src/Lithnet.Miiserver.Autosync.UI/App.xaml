<Application x:Class="Lithnet.Miiserver.AutoSync.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:Lithnet.Miiserver.AutoSync.UI.Controls"
             StartupUri="Windows/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <wpfui:ThemesDictionary Theme="Light" />
                <wpfui:ControlsDictionary />
                <ResourceDictionary Source="/ResourceDictionaries/ErrorNotifications.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <controls:MenuItemContainerTemplateSelector x:Key="MenuItemTemplateSelector" />

            <!-- WPF-UI's disabled button state is very low-contrast; this dims the whole button
                 (background, border, icon and text) so disabled reads clearly in both themes. -->
            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource DefaultButtonStyle}">
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.4" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
